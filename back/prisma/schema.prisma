// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum TransactionType {
  income
  expense
}

enum ExtraIncomeType {
  monthly
  weekly
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  name          String
  transactions  Transaction[]
  financialData FinancialData?
}

model Transaction {
  id          Int      @id @default(autoincrement())
  userId      Int
  amount      Float
  category    String
  date        DateTime
  description String?
  type        TransactionType

  user User @relation(fields: [userId], references: [id])
}

model FinancialData {
  id             Int     @id @default(autoincrement())
  userId         Int     @unique
  salary          Float?
  extraIncome     Float?
  extraIncomeType ExtraIncomeType?
  balance         Float?
  fixedExpenses   Float?

  user User @relation(fields: [userId], references: [id])
}